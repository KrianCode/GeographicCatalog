@model GeographicCatalog.Models.AdminEditFgoViewModel
@{
    ViewData["Title"] = ViewBag.Title ?? "Физ.-гео. объект";
    var regions = ViewBag.Regions as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var districts = ViewBag.Districts as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var fgoTypes = ViewBag.FgoTypes as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var isCreate = Model.Id == 0;
}

<div class="gc-page fade-in">

<nav aria-label="Навигационная цепочка" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Админ-панель</a></li>
        <li class="breadcrumb-item"><a asp-action="ListFgo">Физ.-гео. объекты</a></li>
        <li class="breadcrumb-item active">@(isCreate ? "Создание" : "Редактирование")</li>
    </ol>
</nav>

<h2 class="h4 mb-4" style="color: var(--text-body);">@ViewBag.Title</h2>

<form method="post" asp-action="@(isCreate ? "CreateFgo" : "EditFgo")" asp-route-id="@(isCreate ? (int?)null : Model.Id)">
    @Html.AntiForgeryToken()
    @if (!isCreate) { <input type="hidden" asp-for="Id" /> }

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-3" style="background-color: var(--bg-body); border: 1px solid var(--border-color);">
                <div class="card-header" style="background-color: var(--bg-body); border-bottom: 1px solid var(--border-color);"><strong>Названия</strong></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NAMERUS" class="form-label"></label>
                            <input asp-for="NAMERUS" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NAMEBEL" class="form-label"></label>
                            <input asp-for="NAMEBEL" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NAMELAT" class="form-label"></label>
                            <input asp-for="NAMELAT" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NOMENKLAT" class="form-label"></label>
                            <input asp-for="NOMENKLAT" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UDARRUS" class="form-label"></label>
                            <input asp-for="UDARRUS" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UDARBEL" class="form-label"></label>
                            <input asp-for="UDARBEL" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SINFORUS" class="form-label"></label>
                            <textarea asp-for="SINFORUS" class="form-control" rows="1"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SINFOBEL" class="form-label"></label>
                            <textarea asp-for="SINFOBEL" class="form-control" rows="1"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 mb-3" style="background-color: var(--bg-body); border: 1px solid var(--border-color);">
                <div class="card-header" style="background-color: var(--bg-body); border-bottom: 1px solid var(--border-color);"><strong>Территория, тип, координаты</strong></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="RegionId" class="form-label"></label>
                            <select asp-for="RegionId" class="form-select" id="fgo-region">
                                <option value="">— Выберите —</option>
                                @foreach (var r in regions)
                                {
                                    var isSel = Model.RegionId?.ToString() == r.Value;
                                    <option value="@r.Value" selected="@isSel">@r.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DistrictId" class="form-label"></label>
                            <select asp-for="DistrictId" class="form-select" id="fgo-district">
                                <option value="">— Выберите —</option>
                                @foreach (var d in districts)
                                {
                                    var isSelD = Model.DistrictId?.ToString() == d.Value;
                                    <option value="@d.Value" selected="@isSelD">@d.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TypeId" class="form-label"></label>
                            <select asp-for="TypeId" class="form-select">
                                <option value="">— Выберите —</option>
                                @foreach (var t in fgoTypes)
                                {
                                    var isSelT = Model.TypeId?.ToString() == t.Value;
                                    <option value="@t.Value" selected="@isSelT">@t.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DATEREG" class="form-label"></label>
                            <input asp-for="DATEREG" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EXISTENCE" class="form-label"></label>
                            <input asp-for="EXISTENCE" class="form-control" placeholder="напр. существует" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Y_WGS" class="form-label"></label>
                            <input asp-for="Y_WGS" class="form-control" type="number" step="any" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="X_WGS" class="form-label"></label>
                            <input asp-for="X_WGS" class="form-control" type="number" step="any" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 mb-3" style="background-color: var(--bg-body); border: 1px solid var(--border-color);">
                <div class="card-header" style="background-color: var(--bg-body); border-bottom: 1px solid var(--border-color);"><strong>Гидрография / характеристики</strong></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Basin" class="form-label"></label>
                            <input asp-for="Basin" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Tributary" class="form-label"></label>
                            <input asp-for="Tributary" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FALL" class="form-label"></label>
                            <input asp-for="FALL" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Navigable" class="form-label"></label>
                            <input asp-for="Navigable" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DISTANCE" class="form-label"></label>
                            <input asp-for="DISTANCE" class="form-control" type="number" step="any" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="AREA" class="form-label"></label>
                            <input asp-for="AREA" class="form-control" type="number" step="any" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DEPTH" class="form-label"></label>
                            <input asp-for="DEPTH" class="form-control" type="number" step="any" />
                        </div>
                        <div class="col-12">
                            <label asp-for="SpecialNotes" class="form-label"></label>
                            <textarea asp-for="SpecialNotes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 sticky-top" style="background-color: var(--bg-body); border: 1px solid var(--border-color);">
                <div class="card-body">
                    <button type="submit" class="btn btn-primary w-100 mb-2"><i class="bi bi-check-lg me-1"></i> Сохранить</button>
                    <a asp-action="ListFgo" class="btn btn-outline-secondary w-100">Отмена</a>
                    @if (!isCreate)
                    {
                        <hr />
                        <a asp-controller="Catalog" asp-action="DetailsPhysicalGeo" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary w-100" target="_blank">Открыть в каталоге</a>
                    }
                </div>
            </div>
        </div>
    </div>
</form>

</div>

@section Scripts {
<script>
(function() {
    var getDistrictsUrl = '@Url.Action("GetDistrictsForAdmin", "Admin")';
    document.getElementById('fgo-region').addEventListener('change', function() {
        var rid = this.value;
        var dest = document.getElementById('fgo-district');
        dest.innerHTML = '<option value="">— Выберите —</option>';
        if (!rid) return;
        fetch(getDistrictsUrl + '?regionId=' + encodeURIComponent(rid)).then(function(r) { if (!r.ok) throw new Error(); return r.json(); }).then(function(data) { (data || []).forEach(function(d) { var t = (d.text != null ? d.text : d.Text) || ''; var v = d.value != null ? d.value : d.Value; if (v == null || v === '') return; dest.appendChild(new Option(String(t), String(v))); }); }).catch(function() {});
    });
})();
</script>
}
