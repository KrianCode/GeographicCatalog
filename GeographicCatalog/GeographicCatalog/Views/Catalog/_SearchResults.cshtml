@using GeographicCatalog.Models
@model SearchModel

@if (Model.Results.Any())
{
    <!-- Стилизованная таблица результатов -->
    <div class="table-responsive" style="border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
        <table class="table mb-0" id="resultsTable" style="border-collapse: separate; border-spacing: 0;">
            <thead>
                <tr style="background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);">
                    <th width="40" style="padding: 16px 12px; border: none;">
                        <div style="display: flex; align-items: center; justify-content: center;">
                            <label style="position: relative; cursor: pointer;">
                                <input type="checkbox" class="form-check-input" id="selectAll"
                                       style="width: 20px; height: 20px; border-radius: 6px; border: 2px solid rgba(255,255,255,0.5); background: transparent; cursor: pointer;">
                            </label>
                        </div>
                    </th>
                    <th width="110" style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-tag me-1" style="opacity: 0.7;"></i>Тип
                    </th>
                    <th style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-fonts me-1" style="opacity: 0.7;"></i>Название (рус.)
                    </th>
                    <th style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-translate me-1" style="opacity: 0.7;"></i>Название (бел.)
                    </th>
                    <th style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-diagram-3 me-1" style="opacity: 0.7;"></i>Тип объекта
                    </th>
                    <th style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-map me-1" style="opacity: 0.7;"></i>Область
                    </th>
                    <th style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-pin-map me-1" style="opacity: 0.7;"></i>Район
                    </th>
                    <th style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-geo-alt me-1" style="opacity: 0.7;"></i>Координаты
                    </th>
                    <th width="130" class="text-center" style="padding: 16px 12px; border: none; color: white; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">
                        <i class="bi bi-gear me-1" style="opacity: 0.7;"></i>Действия
                    </th>
                </tr>
            </thead>
            <tbody style="background: white;">
                @{
                    var rowIndex = 0;
                }
                @foreach (var item in Model.Results)
                {
                    var isEven = rowIndex % 2 == 0;
                    var rowBg = isEven ? "#ffffff" : "#f8fafc";
                    rowIndex++;

                    <tr class="search-result-row"
                        style="background: @rowBg; transition: all 0.2s ease; cursor: pointer;"
                        onmouseover="this.style.background='#e8f4fd'; this.style.transform='scale(1.005)';"
                        onmouseout="this.style.background='@rowBg'; this.style.transform='scale(1)';">
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle;">
                            <div style="display: flex; align-items: center; justify-content: center;">
                                <label style="position: relative; cursor: pointer;">
                                    <input type="checkbox" class="form-check-input row-checkbox"
                                           data-id="@item.ObjectId" data-type="@item.ObjectType"
                                           onclick="event.stopPropagation();"
                                           style="width: 18px; height: 18px; border-radius: 5px; border: 2px solid #cbd5e1; cursor: pointer;">
                                </label>
                            </div>
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle;">
                            @{
                                var (badgeGradient, badgeIcon) = item.ObjectType switch
                                {
                                    "ATE" => ("linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%)", "bi-geo"),
                                    "AIR" => ("linear-gradient(135deg, #10b981 0%, #059669 100%)", "bi-airplane"),
                                    "RW" => ("linear-gradient(135deg, #f59e0b 0%, #d97706 100%)", "bi-train-front"),
                                    "FGO" => ("linear-gradient(135deg, #06b6d4 0%, #0891b2 100%)", "bi-water"),
                                    _ => ("linear-gradient(135deg, #64748b 0%, #475569 100%)", "bi-geo-alt")
                                };
                                var typeName = ViewBag.ObjectTypes?[item.ObjectType] as string ?? item.ObjectType;
                            }
                            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 20px; background: @badgeGradient; color: white; font-size: 12px; font-weight: 600; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                                <i class="bi @badgeIcon" style="font-size: 11px;"></i>
                                @typeName
                            </span>
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle;">
                            <div>
                                <a href="@Url.Action("Details", new { type = item.ObjectType, id = item.ObjectId })"
                                   onclick="event.stopPropagation();"
                                   style="font-weight: 600; color: #1e3a5f; text-decoration: none; transition: color 0.2s;"
                                   onmouseover="this.style.color='#3b82f6'; this.style.textDecoration='underline';"
                                   onmouseout="this.style.color='#1e3a5f'; this.style.textDecoration='none';">
                                    @item.NameRu
                                </a>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Nomenklat))
                            {
                                <div style="margin-top: 4px;">
                                    <span style="display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 4px; background: #f1f5f9; color: #64748b; font-size: 11px;">
                                        <i class="bi bi-hash" style="font-size: 10px;"></i>
                                        @item.Nomenklat
                                    </span>
                                </div>
                            }
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle; color: #475569;">
                            @if (!string.IsNullOrEmpty(item.NameBe))
                            {
                                <span style="font-style: italic;">@item.NameBe</span>
                            }
                            else
                            {
                                <span style="color: #cbd5e1;">—</span>
                            }
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle;">
                            <span style="display: inline-block; padding: 5px 10px; border-radius: 8px; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); border: 1px solid #e2e8f0; color: #475569; font-size: 12px; font-weight: 500;">
                                @item.TypeName
                            </span>
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle; color: #475569; font-size: 14px;">
                            @if (!string.IsNullOrEmpty(item.RegionName))
                            {
                                @item.RegionName
                            }
                            else
                            {
                                <span style="color: #cbd5e1;">—</span>
                            }
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle; color: #475569; font-size: 14px;">
                            @if (!string.IsNullOrEmpty(item.DistrictName))
                            {
                                @item.DistrictName
                            }
                            else
                            {
                                <span style="color: #cbd5e1;">—</span>
                            }
                        </td>
                        <td style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle;">
                            @if (!string.IsNullOrEmpty(item.Coordinates))
                            {
                                <div class="coordinates-cell" style="display: flex; align-items: center; gap: 8px;">
                                    <div style="display: flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 8px; background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border: 1px solid #a7f3d0;">
                                        <i class="bi bi-geo-alt" style="color: #10b981; font-size: 12px;"></i>
                                        <span class="coordinates-text" style="font-family: 'Courier New', monospace; font-size: 12px; color: #065f46;">@item.Coordinates</span>
                                    </div>
                                    <button class="btn btn-sm btn-copy-coords"
                                            title="Копировать координаты"
                                            data-coordinates="@item.Coordinates"
                                            onclick="event.stopPropagation();"
                                            style="width: 32px; height: 32px; border-radius: 8px; border: 1px solid #e2e8f0; background: white; color: #64748b; display: flex; align-items: center; justify-content: center; transition: all 0.2s; cursor: pointer;"
                                            onmouseover="this.style.background='#3b82f6'; this.style.color='white'; this.style.borderColor='#3b82f6';"
                                            onmouseout="this.style.background='white'; this.style.color='#64748b'; this.style.borderColor='#e2e8f0';">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 8px; background: #f8fafc; color: #94a3b8; font-size: 12px;">
                                    <i class="bi bi-dash-circle" style="font-size: 11px;"></i>
                                    Не указаны
                                </span>
                            }
                        </td>
                        <td class="text-center" style="padding: 14px 12px; border-bottom: 1px solid #e2e8f0; vertical-align: middle;">
                            <div style="display: flex; align-items: center; justify-content: center; gap: 6px;">
                                <a href="@Url.Action("Details", new { type = item.ObjectType, id = item.ObjectId })"
                                   title="Подробнее"
                                   onclick="event.stopPropagation();"
                                   style="width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); color: white; display: flex; align-items: center; justify-content: center; text-decoration: none; box-shadow: 0 2px 8px rgba(59,130,246,0.3); transition: all 0.2s;"
                                   onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(59,130,246,0.4)';"
                                   onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(59,130,246,0.3)';">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                @if (item.Latitude.HasValue && item.Longitude.HasValue)
                                {
                                    <button type="button"
                                            class="btn show-on-map-btn"
                                            title="Показать на карте"
                                            data-object-type="@item.ObjectType"
                                            data-object-id="@item.ObjectId"
                                            data-name-ru="@item.NameRu"
                                            data-name-be="@item.NameBe"
                                            data-latitude="@item.Latitude"
                                            data-longitude="@item.Longitude"
                                            onclick="event.stopPropagation();"
                                            style="width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; border: none; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(16,185,129,0.3); transition: all 0.2s; cursor: pointer;"
                                            onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(16,185,129,0.4)';"
                                            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(16,185,129,0.3)';">
                                        <i class="bi bi-map"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Панель массовых операций -->
    <div id="bulkOperations" style="display: none; margin-top: 16px;">
        <div style="padding: 16px 20px; border-radius: 12px; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #fcd34d; box-shadow: 0 4px 16px rgba(251,191,36,0.2);">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(245,158,11,0.3);">
                        <i class="bi bi-check2-square" style="color: white; font-size: 18px;"></i>
                    </div>
                    <div>
                        <div style="font-size: 14px; color: #92400e;">Выбрано объектов</div>
                        <div style="font-size: 22px; font-weight: 700; color: #78350f;" id="selectedCount">0</div>
                    </div>
                </div>
                <button id="clearSelectionBtn"
                        style="padding: 10px 20px; border-radius: 10px; border: 2px solid #dc2626; background: white; color: #dc2626; font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 8px; cursor: pointer; transition: all 0.2s;"
                        onmouseover="this.style.background='#dc2626'; this.style.color='white';"
                        onmouseout="this.style.background='white'; this.style.color='#dc2626';">
                    <i class="bi bi-x-circle"></i>
                    Очистить выбор
                </button>
            </div>
        </div>
    </div>
}
else
{
    <!-- Пустое состояние -->
    <div style="padding: 60px 20px; text-align: center; border-radius: 16px; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); border: 2px dashed #cbd5e1;">
        <div style="width: 80px; height: 80px; margin: 0 auto 20px; border-radius: 50%; background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%); display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-search" style="font-size: 32px; color: #94a3b8;"></i>
        </div>
        <h4 style="color: #475569; margin-bottom: 8px;">Объекты не найдены</h4>
        <p style="color: #94a3b8; margin: 0;">Попробуйте изменить параметры поиска или выбрать другой тип объектов</p>
    </div>
}