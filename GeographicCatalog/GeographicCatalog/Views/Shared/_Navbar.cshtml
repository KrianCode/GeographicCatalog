<!-- Навигационная панель -->
<nav class="navbar navbar-expand-lg sticky-top glass-navbar">
    <div class="container-fluid px-lg-4">
        <!-- Логотип -->
        <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
            <div class="brand-icon">
                <i class="bi bi-geo-alt-fill"></i>
            </div>
            <div class="brand-text ms-2">
                <span class="brand-title">ГеоКаталог</span>
                <span class="brand-subtitle">Республика Беларусь</span>
            </div>
            <span class="badge-beta ms-2">Beta</span>
        </a>

        <!-- Кнопка мобильного меню -->
        <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Переключить навигацию">
            <span class="toggler-icon"></span>
            <span class="toggler-icon"></span>
            <span class="toggler-icon"></span>
        </button>

        <!-- Основное меню -->
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <!-- Главная -->
                <li class="nav-item">
                    <a class="nav-link nav-link-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                       asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-2"></i>Главная
                    </a>
                </li>

                <!-- Каталог (Dropdown) -->
                <li class="nav-item dropdown">
                    <a class="nav-link nav-link-custom dropdown-toggle @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" ? "active" : "")"
                       href="#" id="catalogDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-search me-2"></i>Каталог
                    </a>
                    <ul class="dropdown-menu custom-dropdown animate slideIn" aria-labelledby="catalogDropdown">
                        <li>
                            <a class="dropdown-item-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" && ViewBag.ObjectType == "ATE" ? "active" : "")"
                               asp-controller="Catalog" asp-action="Index" asp-route-objectType="ATE">
                                <div class="dropdown-icon bg-gradient-ate">
                                    <i class="bi bi-geo"></i>
                                </div>
                                <div class="dropdown-text">
                                    <div class="title">Населенные пункты</div>
                                    <div class="subtitle">Города, деревни, поселки</div>
                                </div>
                                <span class="dropdown-badge bg-gradient-ate">@(ViewBag.TotalATE ?? 0)</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" && ViewBag.ObjectType == "AIR" ? "active" : "")"
                               asp-controller="Catalog" asp-action="Index" asp-route-objectType="AIR">
                                <div class="dropdown-icon bg-gradient-air">
                                    <i class="bi bi-airplane"></i>
                                </div>
                                <div class="dropdown-text">
                                    <div class="title">Аэропорты</div>
                                    <div class="subtitle">Аэропорты и аэродромы</div>
                                </div>
                                <span class="dropdown-badge bg-gradient-air">@(ViewBag.TotalAirports ?? 0)</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" && ViewBag.ObjectType == "RW" ? "active" : "")"
                               asp-controller="Catalog" asp-action="Index" asp-route-objectType="RW">
                                <div class="dropdown-icon bg-gradient-rw">
                                    <i class="bi bi-train-front"></i>
                                </div>
                                <div class="dropdown-text">
                                    <div class="title">Ж/Д объекты</div>
                                    <div class="subtitle">Станции и остановки</div>
                                </div>
                                <span class="dropdown-badge bg-gradient-rw">@(ViewBag.TotalRailway ?? 0)</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" && ViewBag.ObjectType == "FGO" ? "active" : "")"
                               asp-controller="Catalog" asp-action="Index" asp-route-objectType="FGO">
                                <div class="dropdown-icon bg-gradient-fgo">
                                    <i class="bi bi-water"></i>
                                </div>
                                <div class="dropdown-text">
                                    <div class="title">Физ.-геогр. объекты</div>
                                    <div class="subtitle">Реки, озера, горы</div>
                                </div>
                                <span class="dropdown-badge bg-gradient-fgo">@(ViewBag.TotalFGO ?? 0)</span>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item-simple" asp-controller="Catalog" asp-action="Index">
                                <i class="bi bi-sliders me-2 text-primary"></i>Расширенный поиск
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Карта -->
                <li class="nav-item">
                    <a class="nav-link nav-link-custom disabled-link" href="#">
                        <i class="bi bi-map me-2"></i>Карта
                        <span class="badge-soon">Скоро</span>
                    </a>
                </li>

                <!-- Справочники -->
                <li class="nav-item dropdown">
                    <a class="nav-link nav-link-custom dropdown-toggle" href="#" id="referenceDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-journal-text me-2"></i>Справочники
                    </a>
                    <ul class="dropdown-menu custom-dropdown animate slideIn" aria-labelledby="referenceDropdown">
                        <li>
                            <a class="dropdown-item-simple" href="#">
                                <i class="bi bi-list-ol me-2 text-primary"></i>Классификаторы
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item-simple" href="#">
                                <i class="bi bi-file-text me-2 text-success"></i>Документация
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item-simple" href="#">
                                <i class="bi bi-question-circle me-2 text-danger"></i>Справка
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Администрирование -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" asp-area="" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-gear me-2"></i>Админ
                        </a>
                    </li>
                }
            </ul>

            <!-- Поиск -->
            <form class="search-form d-flex me-3" method="get" asp-controller="Catalog" asp-action="Index">
                <div class="search-group">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="search-input" name="searchQuery" placeholder="Поиск..." value="@ViewBag.SearchQuery">
                </div>
            </form>

            <!-- Правая часть -->
            <ul class="navbar-nav align-items-center">
                <!-- Статистика (скрыта на мобильных) -->
                <li class="nav-item d-none d-xl-block me-3">
                    <div class="stats-badge">
                        <i class="bi bi-database me-2"></i>
                        <span><strong>@(ViewBag.TotalATE + ViewBag.TotalAirports + ViewBag.TotalRailway + ViewBag.TotalFGO ?? 0)</strong> объектов</span>
                    </div>
                </li>

                <!-- Пользователь -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link user-profile dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="user-avatar">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span class="user-name">@User.Identity.Name</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end custom-dropdown animate slideIn" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item-simple" href="#"><i class="bi bi-person me-2"></i>Профиль</a></li>
                            <li><a class="dropdown-item-simple" href="#"><i class="bi bi-gear me-2"></i>Настройки</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item-simple text-danger" asp-area="" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Выход</a></li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn-login" asp-area="" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Вход
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- Хлебные крошки -->
@if (ViewContext.RouteData.Values["Controller"]?.ToString() != "Home" || ViewContext.RouteData.Values["Action"]?.ToString() != "Index")
{
    <nav aria-label="breadcrumb" class="breadcrumb-container">
        <div class="container-fluid px-lg-4">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="home-icon">
                        <i class="bi bi-house-fill"></i>
                    </a>
                </li>

                @if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog")
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Catalog" asp-action="Index" class="breadcrumb-link">Каталог</a>
                    </li>

                    @if (ViewBag.ObjectType != null)
                    {
                        var typeInfo = ViewBag.ObjectType switch
                        {
                            "ATE" => new { Name = "Населенные пункты", Icon = "bi-geo", Class = "bg-gradient-ate" },
                            "AIR" => new { Name = "Аэропорты", Icon = "bi-airplane", Class = "bg-gradient-air" },
                            "RW" => new { Name = "Ж/Д объекты", Icon = "bi-train-front", Class = "bg-gradient-rw" },
                            "FGO" => new { Name = "Физ.-геогр. объекты", Icon = "bi-water", Class = "bg-gradient-fgo" },
                            _ => new { Name = "Все объекты", Icon = "bi-collection", Class = "bg-gradient-ate" }
                        };

                        <li class="breadcrumb-item active">
                            <span class="breadcrumb-badge @typeInfo.Class">
                                <i class="bi @typeInfo.Icon me-1"></i> @typeInfo.Name
                            </span>
                        </li>
                    }
                    else if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
                    {
                        <li class="breadcrumb-item active">
                            <span class="breadcrumb-badge bg-gradient-search">
                                <i class="bi bi-search me-1"></i> «@ViewBag.SearchQuery»
                            </span>
                        </li>
                    }
                }
                else if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Home")
                {
                    <li class="breadcrumb-item active">@ViewData["Title"]</li>
                }
            </ol>
        </div>
    </nav>
}

<style>
    /* --- Variables & Gradients --- */
    :root {
        --nav-bg: #1e3a5f;
        --nav-bg-gradient: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 100%);
        --text-light: rgba(255, 255, 255, 0.96);
        --text-muted: rgba(255, 255, 255, 0.78);
        --hover-bg: rgba(255, 255, 255, 0.1);
        --primary-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }

    html[data-theme="dark"] {
        --nav-bg: #020617;
        --nav-bg-gradient: linear-gradient(135deg, #020617 0%, #020617 100%);
        --text-light: #f8fafc;
        --text-muted: #cbd5e1;
        --hover-bg: rgba(148, 163, 184, 0.18);
        --primary-gradient: linear-gradient(135deg, #3b82f6 0%, #22c55e 100%);
    }

    .bg-gradient-ate {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .bg-gradient-air {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }

    .bg-gradient-rw {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .bg-gradient-fgo {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
    }

    .bg-gradient-search {
        background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%);
        color: #d63384 !important;
    }

    /* --- Navbar Main Styles --- */
    .glass-navbar {
        background: var(--nav-bg-gradient);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        padding: 0.75rem 0;
        transition: all 0.3s ease;
    }

    /* Brand */
    .brand-icon {
        width: 40px;
        height: 40px;
        background: var(--primary-gradient);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
        box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
    }

    .brand-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

    .brand-title {
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
    }

    .brand-subtitle {
        color: var(--text-muted);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .badge-beta {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        font-size: 0.65rem;
        padding: 0.25rem 0.5rem;
        border-radius: 1rem;
        font-weight: 600;
    }

    /* Nav Links */
    .nav-link-custom {
        color: var(--text-light) !important;
        padding: 0.6rem 1rem !important;
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        font-weight: 500;
        margin: 0 0.2rem;
        display: flex;
        align-items: center;
    }

        .nav-link-custom:hover, .nav-link-custom.active {
            background: var(--hover-bg);
            color: white !important;
            transform: translateY(-1px);
        }

    .disabled-link {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .badge-soon {
        background: rgba(255,255,255,0.15);
        font-size: 0.6rem;
        padding: 0.1rem 0.4rem;
        border-radius: 1rem;
        margin-left: 0.5rem;
    }

    /* Dropdowns */
    .custom-dropdown {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        padding: 0.5rem;
        margin-top: 0.5rem;
        min-width: 280px;
    }

    .dropdown-item-custom {
        display: flex;
        align-items: center;
        padding: 0.75rem;
        border-radius: 0.75rem;
        text-decoration: none;
        color: #1e3a5f;
        transition: all 0.2s;
        margin-bottom: 0.25rem;
    }

        .dropdown-item-custom:hover {
            background: #f8fafc;
            transform: translateX(4px);
        }

        .dropdown-item-custom.active {
            background: #f1f5f9;
        }

    .dropdown-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin-right: 1rem;
        flex-shrink: 0;
    }

    .dropdown-text {
        flex-grow: 1;
    }

        .dropdown-text .title {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .dropdown-text .subtitle {
            font-size: 0.75rem;
            color: #64748b;
        }

    .dropdown-badge {
        font-size: 0.75rem;
        color: white;
        padding: 0.15rem 0.5rem;
        border-radius: 1rem;
    }

    .dropdown-item-simple {
        padding: 0.5rem 1rem;
        color: #1e3a5f;
        text-decoration: none;
        display: flex;
        align-items: center;
        border-radius: 0.5rem;
        transition: all 0.2s;
    }

        .dropdown-item-simple:hover {
            background: #f8fafc;
            color: #2563eb;
        }

    /* Search Form */
    .search-group {
        position: relative;
        width: 240px;
        transition: width 0.3s ease;
    }

        .search-group:focus-within {
            width: 300px;
        }

    .search-input {
        width: 100%;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 2rem;
        padding: 0.5rem 1rem 0.5rem 2.5rem;
        color: white;
        transition: all 0.3s;
        font-size: 0.9rem;
    }

        .search-input::placeholder {
            color: rgba(255,255,255,0.5);
        }

        .search-input:focus {
            background: rgba(255,255,255,0.2);
            outline: none;
            border-color: rgba(255,255,255,0.3);
        }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.6);
        pointer-events: none;
    }

    /* User & Stats */
    .stats-badge {
        background: rgba(255,255,255,0.08);
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        color: var(--text-light);
        font-size: 0.85rem;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem !important;
        background: rgba(255,255,255,0.1);
        border-radius: 2rem;
    }

    .user-avatar {
        width: 28px;
        height: 28px;
        background: var(--primary-gradient);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .btn-login {
        background: var(--primary-gradient);
        color: white;
        text-decoration: none;
        padding: 0.5rem 1.2rem;
        border-radius: 2rem;
        font-weight: 500;
        box-shadow: 0 4px 15px rgba(79, 172, 254, 0.3);
        transition: all 0.3s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 172, 254, 0.4);
            color: white;
        }

    /* Mobile Toggler */
    .custom-toggler {
        border: none;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .toggler-icon {
        width: 24px;
        height: 2px;
        background: white;
        border-radius: 2px;
        transition: all 0.3s;
    }

    .custom-toggler[aria-expanded="true"] .toggler-icon:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
    }

    .custom-toggler[aria-expanded="true"] .toggler-icon:nth-child(2) {
        opacity: 0;
    }

    .custom-toggler[aria-expanded="true"] .toggler-icon:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
    }

    /* Breadcrumbs */
    .breadcrumb-container {
        background: var(--color-bg-elevated, #f8fafc);
        border-bottom: 1px solid var(--color-border-soft, #e2e8f0);
        padding: 0.75rem 0;
    }

    .home-icon {
        width: 28px;
        height: 28px;
        background: #e2e8f0;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        transition: all 0.2s;
    }

        .home-icon:hover {
            background: #3b82f6;
            color: white;
        }

    .breadcrumb-link {
        text-decoration: none;
        color: #64748b;
        font-weight: 500;
        transition: color 0.2s;
    }

        .breadcrumb-link:hover {
            color: #3b82f6;
        }

    .breadcrumb-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 1rem;
        color: white;
        font-size: 0.8rem;
        font-weight: 500;
        display: flex;
        align-items: center;
    }

    html[data-theme="dark"] .breadcrumb-link {
        color: #cbd5e1;
    }

        html[data-theme="dark"] .breadcrumb-link:hover {
            color: #93c5fd;
        }

    html[data-theme="dark"] .home-icon {
        background: #1e293b;
        color: #e2e8f0;
    }

        html[data-theme="dark"] .home-icon:hover {
            color: white;
        }

    /* Animations */
    .animate {
        animation-duration: 0.3s;
        animation-fill-mode: both;
    }

    .slideIn {
        animation-name: slideIn;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive Adjustments */
    @@media (max-width: 991px) {
        .navbar-collapse {
            background: var(--nav-bg);
            padding: 1rem;
            border-radius: 1rem;
            margin-top: 1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .search-group {
            width: 100%;
            margin: 1rem 0;
        }

            .search-group:focus-within {
                width: 100%;
            }

        .nav-link-custom {
            padding: 0.8rem !important;
        }

        .dropdown-menu {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .dropdown-item-custom {
            color: white;
        }

            .dropdown-item-custom:hover {
                background: rgba(255,255,255,0.1);
            }

        .dropdown-text .subtitle {
            color: rgba(255,255,255,0.6);
        }

        .dropdown-item-simple {
            color: rgba(255,255,255,0.9);
        }

            .dropdown-item-simple:hover {
                background: rgba(255,255,255,0.1);
                color: white;
            }
    }
</style>