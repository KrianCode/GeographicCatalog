<!DOCTYPE html>
<html lang="ru" data-theme="light" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ГеоКаталог Беларуси</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/accessibility.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">

    @await RenderSectionAsync("Styles", required: false)

    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem('gc-theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                var theme = savedTheme || (prefersDark ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
                document.documentElement.setAttribute('data-bs-theme', theme === 'dark' ? 'dark' : 'light');
                var a11y = localStorage.getItem('gc-accessibility');
                if (a11y === 'on') document.documentElement.setAttribute('data-accessibility', 'on');
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
                document.documentElement.setAttribute('data-bs-theme', 'light');
            }
        })();
    </script>
</head>
<body>
    <a href="#main-content" class="gc-skip-link">Перейти к содержимому</a>

    <div class="gc-topbar d-none d-md-block">
        <div class="gc-topbar-inner">
            <div class="gc-topbar-contacts">
                <a href="tel:+375173347949"><i class="bi bi-telephone"></i>+375 17 334 79 49</a>
                <a href="mailto:info@belgeodesy.by"><i class="bi bi-envelope"></i>info@belgeodesy.by</a>
            </div>
            <span class="gc-topbar-org">ГП «Белгеодезия» · Государственный каталог географических объектов</span>
        </div>
    </div>

    <header class="gc-header">
        <nav class="navbar navbar-expand-lg gc-navbar">
            <div class="container-fluid px-lg-4">
                <a class="gc-brand navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="gc-brand-icon"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i></span>
                    <span class="gc-brand-text">
                        <span class="gc-brand-title">ГеоКаталог</span>
                        <span class="gc-brand-subtitle">Республика Беларусь</span>
                    </span>
                </a>

                <button class="navbar-toggler gc-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Меню">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav gc-nav me-auto mb-2 mb-lg-0 ms-lg-3">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Catalog" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && Context.Request.Query["ObjectType"].Count == 0 ? "active" : "")"
                               asp-area="" asp-controller="Catalog" asp-action="Index">Поиск</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Реестры</a>
                            <ul class="dropdown-menu gc-dropdown">
                                <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Index" asp-route-ObjectType="ATE"><i class="bi bi-geo"></i>Населённые пункты</a></li>
                                <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Index" asp-route-ObjectType="AIR"><i class="bi bi-airplane"></i>Аэропорты</a></li>
                                <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Index" asp-route-ObjectType="RW"><i class="bi bi-train-front"></i>Ж/Д объекты</a></li>
                                <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Index" asp-route-ObjectType="FGO"><i class="bi bi-water"></i>Физ.-геогр. объекты</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="About">О проекте</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")"
                                   asp-area="" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-gear" aria-hidden="true"></i> Админ
                                </a>
                            </li>
                        }
                    </ul>

                    <form class="d-flex align-items-center me-lg-2 mb-2 mb-lg-0" asp-controller="Catalog" asp-action="Index" method="get">
                        <div class="gc-search-group">
                            <i class="bi bi-search gc-search-icon" aria-hidden="true"></i>
                            <input type="text" class="gc-search-input" name="SearchQuery" placeholder="Поиск по каталогу…" aria-label="Поиск по каталогу">
                        </div>
                    </form>

                    <div class="gc-toolbar">
                        <button id="a11yToggleBtn" class="a11y-toggle-btn" type="button" aria-label="Версия для слабовидящих" title="Версия для слабовидящих">
                            <i class="bi bi-eyeglasses" aria-hidden="true"></i><span class="d-none d-xl-inline ms-1">Слабовидящим</span>
                        </button>
                        <button id="themeToggleBtn" class="theme-toggle-btn" type="button" aria-label="Переключить тему">
                            <i id="themeToggleIcon" class="bi bi-moon-fill" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="gc-alert-wrap">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-enterprise alert-enterprise-danger alert-dismissible fade show mt-3" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-circle-fill me-2 fs-5" aria-hidden="true"></i>
                <div><strong>Ошибка:</strong> @TempData["ErrorMessage"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-enterprise alert-enterprise-success alert-dismissible fade show mt-3" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5" aria-hidden="true"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
        </div>
    }
    </div>

    <main id="main-content" role="main" class="gc-main">
        @RenderBody()
    </main>

    <footer class="gc-footer">
        <div class="container gc-footer-main">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="gc-footer-brand">
                        <span class="gc-brand-icon"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i></span>
                        <div>
                            <div class="gc-footer-heading mb-0">ГеоКаталог</div>
                            <small class="opacity-75">Республика Беларусь</small>
                        </div>
                    </div>
                    <p class="small opacity-75 mb-3" style="line-height: 1.65;">
                        Государственный информационный ресурс учёта и стандартизации наименований географических объектов Республики Беларусь.
                    </p>
                    <div class="small opacity-50">Версия 1.0.0</div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <div class="gc-footer-heading">Разделы</div>
                    <a href="@Url.Action("Index", "Home")" class="gc-footer-link">Главная</a>
                    <a href="@Url.Action("Index", "Catalog")" class="gc-footer-link">Каталог</a>
                    <a href="@Url.Action("About", "Home")" class="gc-footer-link">О проекте</a>
                    <button type="button" id="a11yToggleBtnFooter" class="gc-footer-link border-0 bg-transparent p-0 text-start">Версия для слабовидящих</button>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="gc-footer-heading">Контакты</div>
                    <ul class="list-unstyled small opacity-75 mb-0">
                        <li class="mb-2">ГП «Белгеодезия»</li>
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>220029, г. Минск, пр-т Машерова, 17</li>
                        <li class="mb-2"><a href="tel:+375173347949" class="gc-footer-link d-inline mb-0"><i class="bi bi-telephone me-2"></i>+375 17 334 79 49</a></li>
                        <li><a href="mailto:info@belgeodesy.by" class="gc-footer-link d-inline mb-0"><i class="bi bi-envelope me-2"></i>info@belgeodesy.by</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="gc-footer-heading">Внешние ресурсы</div>
                    <a href="https://geo.by" class="gc-footer-link" target="_blank" rel="noopener">Белгеодезия <i class="bi bi-box-arrow-up-right small ms-1"></i></a>
                    <a href="http://maps.by" class="gc-footer-link" target="_blank" rel="noopener">Карты Беларуси <i class="bi bi-box-arrow-up-right small ms-1"></i></a>
                </div>
            </div>
        </div>
        <div class="gc-footer-bottom">
            <div class="container">
                &copy; @DateTime.Now.Year Государственное предприятие «Белгеодезия». Все права защищены.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
