<!-- Модальное окно обратной связи -->
<div class="modal fade" id="contactModal" tabindex="-1" aria-labelledby="contactModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 overflow-hidden" style="background: linear-gradient(135deg, #1a1f2e 0%, #0d1117 100%); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);">
            <!-- Заголовок модального окна -->
            <div class="modal-header border-0 position-relative" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); padding: 1.5rem;">
                <div class="position-absolute top-0 end-0 w-100 h-100 overflow-hidden" style="pointer-events: none;">
                    <div class="position-absolute" style="width: 150px; height: 150px; background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%); top: -75px; right: -75px;"></div>
                </div>
                <div class="d-flex align-items-center position-relative">
                    <div class="d-flex align-items-center justify-content-center rounded-3 me-3"
                         style="width: 44px; height: 44px; background: rgba(255, 255, 255, 0.2);">
                        <i class="bi bi-chat-left-text text-white fs-5"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0 text-white fw-bold" id="contactModalLabel">Обратная связь</h5>
                        <small class="text-white" style="opacity: 0.8;">Мы ответим в течение 24 часов</small>
                    </div>
                </div>
                <button type="button" class="btn-close position-relative" data-bs-dismiss="modal" aria-label="Закрыть"
                        style="filter: brightness(0) invert(1); opacity: 0.8;"></button>
            </div>

            <!-- Тело модального окна -->
            <div class="modal-body p-4">
                <form id="feedbackForm">
                    <div class="mb-4">
                        <label for="feedbackName" class="form-label small fw-medium" style="color: rgba(255, 255, 255, 0.7);">Ваше имя</label>
                        <div class="position-relative">
                            <i class="bi bi-person position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255, 255, 255, 0.4);"></i>
                            <input type="text" class="form-control border-0 ps-5" id="feedbackName" required placeholder="Введите ваше имя"
                                   style="background: rgba(255, 255, 255, 0.08); color: white; padding: 12px 14px 12px 42px; border-radius: 10px;"
                                   onfocus="this.style.background='rgba(59, 130, 246, 0.15)'; this.style.boxShadow='0 0 0 2px rgba(59, 130, 246, 0.3)';"
                                   onblur="this.style.background='rgba(255, 255, 255, 0.08)'; this.style.boxShadow='none';">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="feedbackEmail" class="form-label small fw-medium" style="color: rgba(255, 255, 255, 0.7);">Адрес электронной почты для ответа</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255, 255, 255, 0.4);"></i>
                            <input type="email" class="form-control border-0 ps-5" id="feedbackEmail" required placeholder="ваш.адрес@организация.by"
                                   style="background: rgba(255, 255, 255, 0.08); color: white; padding: 12px 14px 12px 42px; border-radius: 10px;"
                                   onfocus="this.style.background='rgba(59, 130, 246, 0.15)'; this.style.boxShadow='0 0 0 2px rgba(59, 130, 246, 0.3)';"
                                   onblur="this.style.background='rgba(255, 255, 255, 0.08)'; this.style.boxShadow='none';">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="feedbackType" class="form-label small fw-medium" style="color: rgba(255, 255, 255, 0.7);">Тип обращения</label>
                        <div class="position-relative">
                            <i class="bi bi-tag position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); color: rgba(255, 255, 255, 0.4); z-index: 1;"></i>
                            <select class="form-select border-0 ps-5" id="feedbackType"
                                    style="background: rgba(255, 255, 255, 0.08); color: white; padding: 12px 14px 12px 42px; border-radius: 10px; cursor: pointer;"
                                    onfocus="this.style.background='rgba(59, 130, 246, 0.15)'; this.style.boxShadow='0 0 0 2px rgba(59, 130, 246, 0.3)';"
                                    onblur="this.style.background='rgba(255, 255, 255, 0.08)'; this.style.boxShadow='none';">
                                <option value="error" style="background: #1a1f2e;">Сообщение об ошибке</option>
                                <option value="suggestion" style="background: #1a1f2e;">Предложение по улучшению</option>
                                <option value="question" style="background: #1a1f2e;">Вопрос по использованию</option>
                                <option value="data" style="background: #1a1f2e;">Уточнение данных</option>
                                <option value="other" style="background: #1a1f2e;">Другое</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="feedbackMessage" class="form-label small fw-medium" style="color: rgba(255, 255, 255, 0.7);">Сообщение</label>
                        <div class="position-relative">
                            <textarea class="form-control border-0" id="feedbackMessage" rows="4" required placeholder="Опишите ваш вопрос или предложение..."
                                      style="background: rgba(255, 255, 255, 0.08); color: white; padding: 14px; border-radius: 10px; resize: none;"
                                      onfocus="this.style.background='rgba(59, 130, 246, 0.15)'; this.style.boxShadow='0 0 0 2px rgba(59, 130, 246, 0.3)';"
                                      onblur="this.style.background='rgba(255, 255, 255, 0.08)'; this.style.boxShadow='none';"></textarea>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Футер модального окна -->
            <div class="modal-footer border-0 px-4 pb-4 pt-0 gap-2">
                <button type="button" class="btn px-4 py-2 rounded-pill fw-medium" data-bs-dismiss="modal"
                        style="background: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.7); border: 1px solid rgba(255, 255, 255, 0.1); transition: all 0.3s ease;"
                        onmouseover="this.style.background='rgba(255, 255, 255, 0.15)';"
                        onmouseout="this.style.background='rgba(255, 255, 255, 0.08)';">
                    Отмена
                </button>
                <button type="button" class="btn px-4 py-2 rounded-pill fw-medium text-white border-0" onclick="submitFeedback()"
                        style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4); transition: all 0.3s ease;"
                        onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(59, 130, 246, 0.5)';"
                        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(59, 130, 246, 0.4)';">
                    <i class="bi bi-send me-2"></i>Отправить
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function submitFeedback() {
        const form = document.getElementById('feedbackForm');
        if (form.checkValidity()) {
            // Здесь будет отправка формы
            alert('Спасибо за ваше сообщение! Мы рассмотрим его в ближайшее время.');
            $('#contactModal').modal('hide');
            form.reset();
        } else {
            form.reportValidity();
        }
    }
</script>