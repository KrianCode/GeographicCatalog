@{
    ViewData["Title"] = "Государственный каталог наименований географических объектов";
    Layout = "_Layout";
}

@{
    var totalATE = ViewBag.TotalSettlements as int? ?? 0;
    var totalAirports = ViewBag.TotalAirports as int? ?? 0;
    var totalRailway = ViewBag.TotalRailway as int? ?? 0;
    var totalFGO = ViewBag.TotalFGO as int? ?? 0;
    var errorMessage = ViewBag.ErrorMessage as string;
}

<section class="gc-hero">
    <div class="gc-hero-inner">
        <span class="gc-hero-badge">Государственный информационный ресурс</span>
        <h1 class="gc-hero-title">Каталог наименований географических объектов Республики Беларусь</h1>
        <p class="gc-hero-lead">
            Единая система учёта, регистрации и предоставления достоверных сведений о наименованиях географических объектов — для организаций и граждан.
        </p>
        <div class="gc-hero-actions">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-gc-primary">
                <i class="bi bi-search me-2" aria-hidden="true"></i>Начать поиск
            </a>
            <a asp-controller="Home" asp-action="About" class="btn btn-gc-outline">
                О проекте
            </a>
        </div>
    </div>
</section>

<section class="gc-pillars" aria-label="Принципы каталога">
    <div class="gc-pillars-inner">
        <article class="gc-pillar">
            <div class="gc-pillar-num">1</div>
            <h3>Достоверные данные</h3>
            <p>Актуальные, нормализованные сведения о наименованиях на русском и белорусском языках, координатах и кодах СОАТО.</p>
        </article>
        <article class="gc-pillar">
            <div class="gc-pillar-num">2</div>
            <h3>Единый реестр</h3>
            <p>Населённые пункты, аэропорты, объекты железнодорожной инфраструктуры и физико-географические объекты в одном каталоге.</p>
        </article>
        <article class="gc-pillar">
            <div class="gc-pillar-num">3</div>
            <h3>Для специалистов и граждан</h3>
            <p>Поиск, фильтрация, экспорт в CSV и PDF — удобный доступ к пространственным данным о местности.</p>
        </article>
    </div>
</section>

<div class="gc-page fade-in">

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2" aria-hidden="true"></i>
            <div>@errorMessage</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Закрыть"></button>
        </div>
    }

    <section class="mb-5" aria-labelledby="stats-heading">
        <h2 id="stats-heading" class="gc-section-title visually-hidden">Статистика каталога</h2>
        <div class="row g-3 g-lg-4">
            <div class="col-xl-3 col-md-6">
                <div class="gc-stat-card">
                    <div class="gc-stat-icon ate"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i></div>
                    <div class="gc-stat-value">@totalATE.ToString("N0")</div>
                    <div class="gc-stat-label">Населённых пунктов</div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="gc-stat-card">
                    <div class="gc-stat-icon air"><i class="bi bi-airplane-fill" aria-hidden="true"></i></div>
                    <div class="gc-stat-value">@totalAirports.ToString("N0")</div>
                    <div class="gc-stat-label">Аэропортов</div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="gc-stat-card">
                    <div class="gc-stat-icon rw"><i class="bi bi-train-front-fill" aria-hidden="true"></i></div>
                    <div class="gc-stat-value">@totalRailway.ToString("N0")</div>
                    <div class="gc-stat-label">Ж/Д объектов</div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="gc-stat-card">
                    <div class="gc-stat-icon fgo"><i class="bi bi-water" aria-hidden="true"></i></div>
                    <div class="gc-stat-value">@totalFGO.ToString("N0")</div>
                    <div class="gc-stat-label">Физ.-геогр. объектов</div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5" aria-labelledby="registries-heading">
        <h2 id="registries-heading" class="gc-section-title"><i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i> Реестры каталога</h2>
        <div class="row g-3 g-lg-4">
            <div class="col-md-6 col-lg-3">
                <a href="@Url.Action("Index", "Catalog", new { ObjectType = "ATE" })" class="gc-service-card">
                    <div class="gc-service-card-icon ate gc-stat-icon ate mb-0"><i class="bi bi-geo-alt-fill" aria-hidden="true"></i></div>
                    <h3>Населённые пункты</h3>
                    <p>Административно-территориальные единицы: города, посёлки, деревни.</p>
                    <span class="gc-service-card-link">Открыть реестр <i class="bi bi-arrow-right" aria-hidden="true"></i></span>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a href="@Url.Action("Index", "Catalog", new { ObjectType = "AIR" })" class="gc-service-card">
                    <div class="gc-service-card-icon air gc-stat-icon air mb-0"><i class="bi bi-airplane-fill" aria-hidden="true"></i></div>
                    <h3>Аэропорты</h3>
                    <p>Аэропорты и аэродромы воздушного транспорта Республики Беларусь.</p>
                    <span class="gc-service-card-link">Открыть реестр <i class="bi bi-arrow-right" aria-hidden="true"></i></span>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a href="@Url.Action("Index", "Catalog", new { ObjectType = "RW" })" class="gc-service-card">
                    <div class="gc-service-card-icon rw gc-stat-icon rw mb-0"><i class="bi bi-train-front-fill" aria-hidden="true"></i></div>
                    <h3>Железная дорога</h3>
                    <p>Станции, остановочные пункты и объекты железнодорожной инфраструктуры.</p>
                    <span class="gc-service-card-link">Открыть реестр <i class="bi bi-arrow-right" aria-hidden="true"></i></span>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a href="@Url.Action("Index", "Catalog", new { ObjectType = "FGO" })" class="gc-service-card">
                    <div class="gc-service-card-icon fgo gc-stat-icon fgo mb-0"><i class="bi bi-water" aria-hidden="true"></i></div>
                    <h3>Природные объекты</h3>
                    <p>Реки, озёра, горы и другие физико-географические объекты.</p>
                    <span class="gc-service-card-link">Открыть реестр <i class="bi bi-arrow-right" aria-hidden="true"></i></span>
                </a>
            </div>
        </div>
    </section>

    <section class="row g-4" aria-labelledby="about-heading">
        <div class="col-lg-7">
            <h2 id="about-heading" class="gc-section-title"><i class="bi bi-info-circle-fill" aria-hidden="true"></i> О системе</h2>
            <div class="gc-content-card">
                <p class="mb-4">
                    Государственный каталог наименований географических объектов — электронный информационный ресурс ГП «Белгеодезия», содержащий актуальные сведения о наименованиях географических объектов Республики Беларусь.
                </p>
                <div class="row g-4">
                    <div class="col-md-6">
                        <h3 class="h6 fw-bold mb-3">Возможности</h3>
                        <ul class="gc-feature-list">
                            <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i> Поиск на русском и белорусском</li>
                            <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i> Фильтрация по регионам и типам</li>
                            <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i> Экспорт в CSV и PDF</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h3 class="h6 fw-bold mb-3">Нормативная база</h3>
                        <ul class="gc-feature-list">
                            <li><i class="bi bi-file-earmark-text-fill" aria-hidden="true"></i> Закон «О наименованиях географических объектов»</li>
                            <li><i class="bi bi-file-earmark-text-fill" aria-hidden="true"></i> Инструкции ГКИ Республики Беларусь</li>
                        </ul>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top">
                    <a href="@Url.Action("About", "Home")" class="gc-link-arrow">
                        Подробнее о проекте <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <h2 class="gc-section-title"><i class="bi bi-shield-lock-fill" aria-hidden="true"></i> Администрирование</h2>
            <div class="gc-content-card d-flex flex-column h-100">
                <p class="text-muted mb-4">Вход для сотрудников, осуществляющих ведение и актуализацию данных каталога.</p>
                <a asp-controller="Account"
                   asp-action="Login"
                   asp-route-returnUrl="@Url.Content("~/Admin")"
                   class="btn btn-gc-primary mt-auto align-self-start">
                    <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Вход в админ-панель
                </a>
            </div>
        </div>
    </section>
</div>
