@model GeographicCatalog.Models.LoginViewModel
@{
    ViewData["Title"] = "Вход в админ-панель";
    Layout = "_Layout";
    var returnUrl = ViewData["ReturnUrl"] as string ?? "/Admin";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h1 class="h4 mb-4 text-center">Вход в админ-панель</h1>
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <form method="post" asp-action="Login" asp-controller="Account">
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <div class="mb-3">
                            <label asp-for="Login" class="form-label"></label>
                            <input asp-for="Login" class="form-control" autocomplete="username" autofocus />
                            <span asp-validation-for="Login" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small"></label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Войти</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
